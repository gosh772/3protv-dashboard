# ──────────────────────────────────────────────────────────────
# .env.example  →  복사하여 .env 로 이름 변경 후 값을 채워 넣으세요
# ──────────────────────────────────────────────────────────────

# [필수] YouTube Data API v3 키
# 발급 방법: https://console.cloud.google.com → API 사용 설정 → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# [선택] Anthropic Claude API 키 (Claude를 선택할 경우 필요)
# 발급: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# [선택] OpenAI API 키 (GPT를 선택할 경우 필요)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
